
programa {
    funcao inicio() {
        real nota
        
        escreva("Qual nota você me dá?: ")
        leia(nota)
        
        se (nota >= 7) {
            escreva("Você é foda, também te dou nota " , nota  )
        } senao {
            escreva("Seu lixo")
        }
    }
}
            
